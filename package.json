{
  "name": "rollup-plugin-resolve-shebang",
  "version": "1.0.1",
  "description": "Rollup plugin with recognize shebang and preserve it",
  "keywords": [
    "rollup",
    "rollup-plugin",
    "shebang"
  ],
  "homepage": "https://github.com/mister-hope/rollup-plugin-resolve-shebang#readme",
  "bugs": {
    "url": "https://github.com/mister-hope/rollup-plugin-resolve-shebang/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com//mister-hope/rollup-plugin-resolve-shebang.git"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf ./dist",
    "dev": "tsdown -w",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "prepublish": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.4",
    "oxc-config-hope": "0.3.5",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "rimraf": "6.1.3",
    "tsdown": "0.22.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "rollup": ">=4"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.1",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
